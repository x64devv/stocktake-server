# ── Required — app will not start without these ───────────────────────────────
DB_PASSWORD=change_me_strong_password
REDIS_PASSWORD=change_me_redis_password

# Generate with: openssl rand -hex 32
JWT_SECRET=change_me_jwt_secret_at_least_32_chars_long
OTP_SECRET=change_me_otp_secret_at_least_32_chars_long

# ── SMS gateway — required for OTP delivery to counters ───────────────────────
SMS_BASE_URL=https://sms.localhost.co.zw/api
SMS_API_KEY=your_sms_api_key_here

# ── LS Commerce Service — required for worksheet pull and final submission ────
LS_BASE_URL=https://your-bc-server/BC220/ODataV4
LS_USERNAME=your_bc_service_username
LS_PASSWORD=your_bc_service_password
LS_COMPANY_ID=your_bc_company_id

# ── Optional tuning (defaults shown) ─────────────────────────────────────────
OTP_EXPIRY_MINUTES=10
OTP_MAX_REQUESTS=3
COUNTER_TOKEN_HOURS=12
ADMIN_TOKEN_HOURS=8
VARIANCE_TOLERANCE_PCT=2.0
